---
import Layout from "@/layouts/Layout.astro";
import Header from "@/sections/Header.astro";
import SiteFooter from "@/sections/SiteFooter.astro";
import { DICT, DEFAULT_LANG } from "@/consts/i18n";
import { DOCS } from "@/consts/docs";

const landingCopy = DICT[DEFAULT_LANG];
const docs = DOCS[DEFAULT_LANG];
---

<Layout copy={landingCopy}>
  <a class="skip" href="#docs-main">{landingCopy.skip}</a>
  <Header copy={landingCopy} />

  <main id="docs-main" class="docs-layout">
    <aside class="docs-toc">
      <strong id="toc-label">{docs.tocLabel}</strong>
      {
        docs.sections.map((sec) => (
          <a href={`#${sec.id}`} data-i18n-toc={sec.id}>{sec.title}</a>
        ))
      }
    </aside>

    <article class="docs-content">
      <h1 id="page-title">{docs.pageTitle}</h1>
      <p class="docs-subtitle" id="page-subtitle">{docs.subtitle}</p>
      {
        docs.sections.map((sec) => (
          <section id={sec.id}>
            <h2 data-i18n-heading={sec.id}>{sec.title}</h2>
            <div set:html={sec.html} />
          </section>
        ))
      }
    </article>
  </main>

  <SiteFooter copy={landingCopy} />
</Layout>

<script>
  import "@/scripts/docs-client.ts";
</script>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: 230px 1fr;
    gap: 40px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }
  .docs-toc {
    position: sticky;
    top: 82px;
    align-self: start;
    font-size: .93rem;
  }
  .docs-toc strong {
    display: block;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .04em;
    font-size: .74rem;
    margin: 0 0 10px;
  }
  .docs-toc a {
    display: block;
    color: var(--text-muted);
    padding: 5px 0;
  }
  .docs-toc a:hover { color: var(--text); text-decoration: none; }

  .docs-content h1 {
    font-size: 2.1rem;
    line-height: 1.15;
    margin: .2em 0 .1em;
    font-weight: 800;
    letter-spacing: -.01em;
  }
  .docs-subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin: 0 0 8px;
  }
  .docs-content section {
    scroll-margin-top: 78px;
    padding: 26px 0;
    border-top: 1px solid var(--border);
  }
  .docs-content section:first-of-type { border-top: 0; }
  .docs-content h2 {
    font-size: 1.45rem;
    margin: 0 0 .5em;
    font-weight: 700;
  }
  .docs-content h3 {
    font-size: 1.08rem;
    margin: 1.4em 0 .3em;
    font-weight: 650;
  }
  .docs-content :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: .9em;
    background: var(--surface-2);
    padding: .12em .4em;
    border-radius: 3px;
  }
  .docs-content :global(pre) {
    background: var(--text);
    color: var(--bg);
    padding: 16px 18px;
    border-radius: var(--radius);
    overflow-x: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: .86rem;
    line-height: 1.5;
  }
  .docs-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .docs-content :global(.cards) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 16px;
    margin: 14px 0;
  }
  .docs-content :global(.card) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px;
  }
  .docs-content :global(.card h3) { margin-top: 0; }
  .docs-content :global(.note) {
    background: var(--surface-2);
    border-left: 3px solid var(--text);
    padding: 12px 16px;
    border-radius: 0 var(--radius) var(--radius) 0;
    margin: 16px 0;
    color: var(--text-muted);
  }
  .docs-content :global(.note strong) { color: var(--text); }
  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: .95rem;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    text-align: left;
    padding: 9px 10px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .docs-content :global(th) { color: var(--text-muted); font-weight: 600; }
  .docs-content :global(td code) { white-space: nowrap; }

  @media (max-width: 820px) {
    .docs-layout { grid-template-columns: 1fr; }
    .docs-toc { display: none; }
  }
</style>
