---
import type { Copy } from "@/consts/i18n";
import { DONATIONS } from "@/consts/site";

interface Props { copy: Copy }
const { copy } = Astro.props;

// Iconos por plataforma de donación.
const ICONS: Record<string, string> = {
  paypal: '<path d="M7 20l1.5-9h4.5a3.5 3.5 0 0 0 0-7H8L5 20"/><path d="M9 15h3.5a3.5 3.5 0 0 0 0-7"/>',
  kofi: '<path d="M4 8h13v5a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V8Z"/><path d="M17 9h2.2a2.3 2.3 0 0 1 0 4.6H17"/><path d="M8 3.5v1.5M12 3.5v1.5"/>',
  ghsponsors: '<path d="M12 20.5C6 16.5 3.5 12.8 3.5 9.4A4 4 0 0 1 12 7a4 4 0 0 1 8.5 2.4c0 3.4-2.5 7.1-8.5 11.1Z"/>',
};
---
<section class="support">
  <div class="wrap">
    <div class="support-card">
      <h2 data-i18n="supTitle">{copy.supTitle}</h2>
      <p data-i18n="supText">{copy.supText}</p>
      <div class="support-links">
        {DONATIONS.map((d) => (
          <a class="chip" href={d.href} target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[d.id]} />
            {d.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .support { text-align: center; }
  .support-card {
    max-width: 640px; margin: 0 auto;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 34px 28px;
  }
  .support h2 { font-size: 1.5rem; }
  .support p { color: var(--text-muted); margin-top: 10px; }
  .support-links { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 22px; }
  .chip {
    display: inline-flex; align-items: center; gap: 9px;
    background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 10px 16px; color: var(--text); font-weight: 600; font-size: 0.95rem;
  }
  .chip:hover { text-decoration: none; border-color: var(--border-strong); }
  .chip svg { flex: none; }
</style>
