---
import type { Copy } from "@/consts/i18n";
import { DOWNLOADS, RELEASES_URL, RELEASE_VERSION } from "@/consts/site";

interface Props { copy: Copy }
const { copy } = Astro.props;
const dlFoot = copy.dlFoot.replace("{version}", RELEASE_VERSION);
---
<section id="descargas" class="downloads">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow" data-i18n="dlEyebrow">{copy.dlEyebrow}</span>
      <h2 data-i18n="dlTitle">{copy.dlTitle}</h2>
      <p data-i18n="dlLead">{copy.dlLead}</p>
    </div>
    <div class="os-grid">
      {DOWNLOADS.map((dl) => (
        <div class="os-card" data-os={dl.os}>
          <div class="os-head">
            <span class="os-ico" aria-hidden="true">
              {dl.os === "linux" && (
                <img src="/icons/linux.png" alt="" width="34" height="auto" />
              )}
              {dl.os === "mac" && (
                <img src="/icons/mac.png" alt="" width="34" height="auto" />
              )}
              {dl.os === "windows" && (
                <img src="/icons/windows.png" alt="" width="34" height="auto" />
              )}
            </span>
            <span class="os-tag">
              <svg class="tag-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
              <span data-i18n="osTag">{copy.osTag}</span>
            </span>
          </div>
          <h3>{dl.name}</h3>
          <p class="fmt">{dl.fmt}</p>
          <a class="btn btn-primary btn-dl" href={dl.href}>
            <span data-i18n={dl.ctaKey}>{copy[dl.ctaKey]}</span>
            <svg class="dl-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
          </a>
          {dl.altHref && dl.altKey && (
            <div class="alt-wrap">
              <a class="alt" href={dl.altHref}>
                <svg class="dl-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
                <span data-i18n={dl.altKey}>{copy[dl.altKey]}</span>
              </a>
            </div>
          )}
        </div>
      ))}
    </div>
    <p class="dl-foot">
      <span data-i18n="dlFoot">{dlFoot}</span>
      <a class="dl-all" href={RELEASES_URL}>
        <span data-i18n="dlAll">{copy.dlAll}</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg>
      </a>
    </p>
  </div>
</section>

<style>
  .downloads { background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .os-grid { display: grid; grid-template-columns: 1fr; gap: 20px; align-items: stretch; }
  @media (min-width: 760px) { .os-grid { grid-template-columns: repeat(3, 1fr); } }
  .os-card {
    display: flex; flex-direction: column; align-items: stretch;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 24px; box-shadow: var(--shadow);
  }
  .os-card.is-user { border-color: var(--border-strong); box-shadow: var(--shadow), 0 0 0 1px var(--border-strong) inset; order: -1; }

  /* Cabecera: icono a la izquierda, etiqueta "detectado" a la derecha, en línea. */
  .os-head { display: flex; align-items: center; justify-content: space-between; min-height: 34px; margin-bottom: 14px; }
  .os-ico { color: var(--text); display: inline-flex; }
  .os-ico img { width: 34px; height: auto; object-fit: contain; object-position: center left; }
  .os-tag {
    display: none; align-items: center; gap: 6px;
    background: var(--surface-2); border: 1px solid var(--border);
    color: var(--text-muted); font-size: 0.76rem; font-weight: 600;
    padding: 4px 10px 4px 8px; border-radius: var(--radius);
  }
  .os-tag .tag-check { color: var(--text); }
  .os-card.is-user .os-tag { display: inline-flex; }

  .os-card h3 { font-size: 1.22rem; }
  .fmt { color: var(--text-muted); font-size: 0.9rem; margin-top: 4px; margin-bottom: 18px; }

  /* El botón queda alineado entre tarjetas porque el bloque superior mide igual. */
  .os-card .btn { width: 100%; }
  .btn-dl { position: relative; padding-left: 20px; padding-right: 38px; }
  .btn-dl > span { min-width: 0; }
  .btn-dl .dl-icon { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); }

  /* Enlace secundario: alineado a la izquierda tras un separador sutil. */
  .alt-wrap { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border); }
  .os-card .alt {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--text-muted); font-size: 0.86rem;
  }
  .os-card .alt .dl-icon { color: var(--text-muted); flex-shrink: 0; }
  .os-card .alt:hover { color: var(--text); }
  .os-card .alt:hover .dl-icon { color: var(--text); }

  .dl-foot {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 6px 14px;
    text-align: center; margin-top: 34px; color: var(--text-muted); font-size: 0.95rem;
  }
  .dl-all { display: inline-flex; align-items: center; gap: 5px; }
  .dl-all svg { transition: transform .15s ease; }
  .dl-all:hover svg { transform: translateX(2px); }
</style>
