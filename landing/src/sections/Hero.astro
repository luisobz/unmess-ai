---
import type { Copy } from "@/consts/i18n";
import { SITE } from "@/consts/site";
import VersionHistoryArt from "@/components/VersionHistoryArt.astro";

interface Props { copy: Copy }
const { copy } = Astro.props;
---
<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="kicker">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="1"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
        <span data-i18n="heroKicker">{copy.heroKicker}</span>
      </span>
      <h1><span class="brandword">{SITE.name}</span><br><span data-i18n="heroTitle">{copy.heroTitle}</span></h1>
      <p class="lead" data-i18n="heroLead">{copy.heroLead}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#descargas">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4"/><path d="M5 21h14"/></svg>
          <span data-i18n="heroCta">{copy.heroCta}</span>
        </a>
        <a class="btn btn-ghost" href="/docs/" data-i18n="heroDocs">{copy.heroDocs}</a>
      </div>
      <div class="trust">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4 10-11"/></svg><span data-i18n="trust1">{copy.trust1}</span></span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4 10-11"/></svg><span data-i18n="trust2">{copy.trust2}</span></span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4 10-11"/></svg><span data-i18n="trust3">{copy.trust3}</span></span>
      </div>
    </div>
    <VersionHistoryArt alt={copy.artAlt} />
  </div>
</section>

<style>
  .hero { padding: 64px 0 40px; }
  .hero-grid { display: grid; grid-template-columns: 1fr; gap: 44px; align-items: center; }
  @media (min-width: 900px) { .hero-grid { grid-template-columns: 1.05fr 0.95fr; gap: 56px; } }
  .kicker {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--text-muted); font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;
  }
  .kicker svg { flex: none; opacity: 0.75; }
  .hero h1 { font-size: clamp(2.1rem, 6vw, 3.5rem); letter-spacing: -0.035em; }
  .hero h1 .brandword { color: var(--text); }
  .lead { color: var(--text-muted); font-size: clamp(1.05rem, 2.4vw, 1.28rem); margin-top: 20px; max-width: 34ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 32px; }
  .trust { display: flex; flex-wrap: wrap; gap: 8px 20px; margin-top: 28px; color: var(--text-muted); font-size: 0.9rem; }
  .trust > span { display: inline-flex; align-items: center; gap: 7px; }
  .trust svg { color: var(--accent); flex: none; }
</style>
