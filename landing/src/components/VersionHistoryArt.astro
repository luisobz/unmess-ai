---
// Ilustración del hero: historial de versiones de un archivo con versiones
// anteriores restaurables. SVG inline (sin peticiones externas), monocromo.
interface Props { alt: string }
const { alt } = Astro.props;
---
<div class="hero-art">
  <svg viewBox="0 0 420 320" role="img" aria-label={alt}>
    <g opacity="0.5">
      <rect x="86" y="34" width="228" height="52" rx="3" fill="var(--surface)" stroke="var(--border-strong)"/>
    </g>
    <g opacity="0.75">
      <rect x="72" y="52" width="256" height="58" rx="3" fill="var(--surface)" stroke="var(--border-strong)"/>
    </g>
    <line x1="52" y1="120" x2="52" y2="286" stroke="var(--border-strong)" stroke-width="2"/>
    <g font-family="inherit">
      <circle cx="52" cy="140" r="7" fill="var(--accent)"/>
      <rect x="72" y="118" width="286" height="46" rx="3" fill="var(--surface)" stroke="var(--accent)" stroke-width="1.5"/>
      <text x="92" y="140" fill="var(--text)" font-size="15" font-weight="700">informe.md</text>
      <text x="92" y="156" fill="var(--text-muted)" font-size="11">v2026-07-11-14-30 · actual</text>
      <path d="m316 135 5 5 9-10" fill="none" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="52" cy="200" r="6" fill="var(--surface)" stroke="var(--border-strong)" stroke-width="2"/>
      <rect x="72" y="180" width="286" height="42" rx="3" fill="var(--surface-2)" stroke="var(--border)"/>
      <text x="92" y="200" fill="var(--text)" font-size="13" font-weight="600">informe.md</text>
      <text x="92" y="215" fill="var(--text-muted)" font-size="10.5">v2026-07-11-09-05</text>
      <rect x="286" y="190" width="60" height="22" rx="2" fill="var(--accent)"/>
      <text x="316" y="205" fill="var(--on-accent)" font-size="10.5" font-weight="700" text-anchor="middle">restaurar</text>
      <circle cx="52" cy="258" r="6" fill="var(--surface)" stroke="var(--border-strong)" stroke-width="2"/>
      <rect x="72" y="238" width="286" height="42" rx="3" fill="var(--surface-2)" stroke="var(--border)"/>
      <text x="92" y="258" fill="var(--text)" font-size="13" font-weight="600">informe.md</text>
      <text x="92" y="273" fill="var(--text-muted)" font-size="10.5">v2026-07-10-18-42</text>
      <rect x="286" y="248" width="60" height="22" rx="2" fill="none" stroke="var(--border-strong)"/>
      <text x="316" y="263" fill="var(--text-muted)" font-size="10.5" font-weight="700" text-anchor="middle">restaurar</text>
    </g>
  </svg>
</div>

<style>
  .hero-art { display: flex; justify-content: center; }
  .hero-art svg { width: 100%; max-width: 440px; height: auto; filter: drop-shadow(var(--shadow-lg)); }
</style>
